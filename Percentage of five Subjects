#include<stdio.h>
int main()
{
   int phy,chem,bio,math,comp;
   float per;
   printf("Enter five subjects marks:");
   scanf("%d%d%d%d%d",&phy,&chem,&bio,&math,&comp);
   per=(phy+chem+bio+math+comp)/5;
   printf("Percentage=%",per);
   if(per >=90)
   {
     printf("Grade A");
   }
   else if(per >=70)
   {
     printf("Grade B");
   }
   else if(per >=50)
   {
     printf("Grade C");
   }
   else if (per <50)
   {
     printf("Fail");
   }
   return 0;
}
